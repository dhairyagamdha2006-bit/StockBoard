# ============================================================
# StockBoard — Environment Variables
# Copy to `.env.local` and fill in real values. NEVER commit secrets.
# ============================================================

# --- Supabase (required) -----------------------------------
# Project URL + anon key are public (exposed to the browser).
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key...
# Service-role key is SERVER-ONLY. Bypasses RLS — never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key...

# --- Token encryption (required) ---------------------------
# Used to AES-256-GCM encrypt broker tokens at rest. The app REFUSES to start
# storing tokens without a real key. Generate one with: openssl rand -hex 32
ENCRYPTION_KEY=replace_me_with_openssl_rand_hex_32

# --- Cron auth (required in production) ---------------------
# Vercel Cron sends `Authorization: Bearer ${CRON_SECRET}` to /api/sync/all.
# Generate with: openssl rand -hex 32
CRON_SECRET=replace_me_with_openssl_rand_hex_32

# --- Alpaca Markets (required for live prices) --------------
ALPACA_API_KEY=your_alpaca_key
ALPACA_SECRET_KEY=your_alpaca_secret

# --- E*TRADE OAuth 1.0a (optional) -------------------------
ETRADE_CONSUMER_KEY=your_etrade_consumer_key
ETRADE_CONSUMER_SECRET=your_etrade_consumer_secret
ETRADE_REDIRECT_URI=http://localhost:3000/connect/etrade/callback

# --- Charles Schwab OAuth 2.0 (optional) -------------------
SCHWAB_CLIENT_ID=your_schwab_client_id
SCHWAB_CLIENT_SECRET=your_schwab_client_secret
SCHWAB_REDIRECT_URI=https://127.0.0.1:3000/connect/schwab/callback

# --- Robinhood (EXPERIMENTAL, optional) --------------------
# Robinhood has NO public API. This uses an unofficial private endpoint with
# username/password and is OFF by default. Not recommended for real accounts.
# Set to "true" only if you understand and accept the risk.
ENABLE_ROBINHOOD_EXPERIMENTAL=false

# --- Upstash Redis (optional, recommended for production) ---
# Enables distributed rate limiting across serverless instances. If unset,
# StockBoard falls back to an in-memory limiter (fine for single-instance/dev).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
